base:
  'dom0':
    - match: nodegroup
    - homelab-dev.create
  'tpl-homelab-dev':
    - homelab-dev.install
  'dvm-homelab-dev':
    - homelab-dev.configure-dvm
  'homelab-dev':
    - homelab-dev.configure
  '(I@qubes:type:template or I@qubes:type:standalone) and (G@kernel:Linux or G@kernel:*BSD)':
    - match: compound
    - sys-net.install-proxy
