## AWS credential_process helper for client qubes.
## Requests short-lived credentials from sys-aws via Qrexec.
##
## Usage in ~/.aws/config:
##   [profile sandbox]
##   credential_process = qusal-aws-credential sandbox
##   region = us-east-1

set -eu

die(){
  printf '%s\n' "error: ${1}" >&2
  exit 1
}

profile="${1-}"

if test -z "${profile}"; then
  die "Usage: ${0##*/} <profile>"
fi

exec qrexec-client-vm -- @default qusal.AwsCred+"${profile}"
